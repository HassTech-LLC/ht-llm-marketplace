{
  "name": "ht-llm-marketplace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lightweight local-first LLM marketplace, runtime control plane, and embeddable model manager.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HassTech-LLC/ht-llm-marketplace.git"
  },
  "homepage": "https://github.com/HassTech-LLC/ht-llm-marketplace#readme",
  "bugs": {
    "url": "https://github.com/HassTech-LLC/ht-llm-marketplace/issues"
  },
  "keywords": [
    "llm",
    "local-ai",
    "gguf",
    "ollama",
    "llama-cpp",
    "huggingface",
    "web-component",
    "openai-compatible",
    "ai-agents"
  ],
  "workspaces": [
    "packages/sdk",
    "packages/react",
    "packages/web-component",
    "packages/daemon",
    "packages/cli",
    "apps/studio"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n daemon,studio -c green,cyan \"npm run dev -w @ht-llm-marketplace/daemon\" \"npm run dev -w @ht-llm-marketplace/studio\"",
    "studio": "npm run dev",
    "start:daemon": "npm run start -w @ht-llm-marketplace/daemon",
    "dev:daemon": "npm run dev -w @ht-llm-marketplace/daemon",
    "dev:studio": "npm run dev -w @ht-llm-marketplace/studio",
    "build": "node scripts/clean-dist.mjs && npm run check && npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "pack:dry-run": "npm pack --dry-run -w @ht-llm-marketplace/sdk && npm pack --dry-run -w @ht-llm-marketplace/react && npm pack --dry-run -w @ht-llm-marketplace/web-component && npm pack --dry-run -w @ht-llm-marketplace/daemon && npm pack --dry-run -w @ht-llm-marketplace/cli",
    "smoke:packages": "node scripts/package-smoke.mjs",
    "check:artifacts": "node scripts/check-artifacts.mjs",
    "check:compatibility": "node scripts/compatibility-smoke.mjs",
    "smoke:server-quality": "node scripts/server-quality-smoke.mjs",
    "smoke:server-gauntlet": "node scripts/server-replacement-gauntlet.mjs",
    "smoke:delegated-server": "node scripts/delegated-server-smoke.mjs",
    "smoke:server-pool": "node scripts/server-pool-smoke.mjs",
    "smoke:docker": "node scripts/smoke-docker.mjs",
    "smoke:docker:required": "node scripts/smoke-docker.mjs --required",
    "smoke:installer": "node scripts/smoke-installer.mjs",
    "smoke:studio": "node scripts/playwright-studio-smoke.mjs",
    "smoke:marketplace": "node scripts/playwright-marketplace-smoke.mjs",
    "smoke:cli-marketplace": "node scripts/cli-marketplace-smoke.mjs",
    "smoke:universal": "node scripts/universal-integration-smoke.mjs",
    "smoke:consumer": "node scripts/consumer-clean-room-smoke.mjs",
    "smoke:consumer:fast": "node scripts/consumer-clean-room-smoke.mjs --skip-build",
    "smoke:docs": "node scripts/docs-quality-smoke.mjs",
    "docs:assets": "node scripts/playwright-marketplace-smoke.mjs --docs-assets",
    "docs:terminal": "node scripts/terminal-proof-assets.mjs",
    "peak:smoke": "node scripts/peak-smoke.mjs",
    "desktop:check": "npm --prefix apps/desktop run check",
    "desktop:build": "npm --prefix apps/desktop run build",
    "desktop:dev": "npm --prefix apps/desktop run dev",
    "profile:runtime": "node packages/cli/src/index.js profile runtime-only",
    "profile:embed": "node packages/cli/src/index.js profile embed-ui",
    "profile:studio": "node packages/cli/src/index.js profile studio-full",
    "profile:agent": "node packages/cli/src/index.js profile terminal-agent",
    "bundle:local": "node scripts/local-release-bundle.mjs",
    "publish:dry-run": "node scripts/npm-publish-dry-run.mjs",
    "release:preflight": "node scripts/release-preflight.mjs",
    "release:preflight:ci": "node scripts/release-preflight.mjs --docker-required",
    "ci:status": "node scripts/ci-status.mjs",
    "engine:lean": "node scripts/lean-engine.mjs",
    "engine:gpu-proof": "node scripts/llama-gpu-proof.mjs",
    "release:check": "npm run check && npm test && npm run build && npm run check:compatibility && npm run smoke:docs && npm run smoke:cli-marketplace && npm run smoke:universal && npm run smoke:marketplace && npm run pack:dry-run && npm run smoke:packages && npm run check:artifacts",
    "rebuild:cuda": "node scripts/rebuild-cuda.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run check"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "playwright": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
